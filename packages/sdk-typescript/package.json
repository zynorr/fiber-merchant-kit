{
  "name": "@fiber-merchant/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for Fiber Merchant Kit — integrate Fiber payments into any application",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "ofetch": "^1.3.3"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.7"
  },
  "keywords": ["fiber", "nervos", "ckb", "payment", "lightning", "merchant"],
  "license": "MIT"
}
