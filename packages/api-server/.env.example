# Fiber Merchant Kit API server
#
# start.sh and start.ps1 copy this file to packages/api-server/.env and load it.
# If you run npm scripts directly, export these variables in your shell or
# deployment environment before starting the API server.

NODE_ENV=development
PORT=3001
CORS_ORIGIN=*
FIBER_MERCHANT_DB_PATH=data/merchant.db
FIBER_DB_ENGINE=sqlite
DATABASE_URL=

# Demo mode: leave unset or set to demo.
FIBER_NODE_RPC_URL=demo
# Optional comma-separated failover list. When set, it takes precedence over FIBER_NODE_RPC_URL.
FIBER_NODE_RPC_URLS=
FIBER_NODE_CURRENCY=Fibt

# Preferred for protected Fiber RPC endpoints.
FIBER_NODE_RPC_AUTH_TOKEN=

# Optional basic-auth fallback for private/local RPC endpoints.
FIBER_NODE_RPC_USER=
FIBER_NODE_RPC_PASSWORD=

# Leave FIBER_SETTLEMENT_WORKER unset for default behavior:
# disabled in demo mode, enabled in live mode.
FIBER_SETTLEMENT_WORKER_INTERVAL_MS=30000
FIBER_SETTLEMENT_WORKER_BATCH_SIZE=25

# Durable webhook delivery worker.
WEBHOOK_DELIVERY_WORKER=true
WEBHOOK_DELIVERY_WORKER_INTERVAL_MS=5000
WEBHOOK_DELIVERY_WORKER_BATCH_SIZE=25

DISABLE_RATE_LIMIT=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Optional hosted-demo helper. Only set true on an explicit demo deployment
# where NODE_ENV is not production and FIBER_NODE_RPC_URL is demo/unset.
EXPOSE_DEMO_KEY=false

# Optional real testnet smoke knobs.
FIBER_TESTNET_CREATE_INVOICE=false
FIBER_TESTNET_AMOUNT=1000
FIBER_TESTNET_EXPIRY=3600
