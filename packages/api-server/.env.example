# Fiber Merchant API Server Configuration
# Copy this file to .env and fill in your values.

# Server port (default: 3001)
PORT=3001

# Fiber Network Node RPC endpoint
# Set to your FNN node URL for production, or leave commented for demo mode
# FIBER_NODE_RPC_URL=http://localhost:8227
# Preferred for protected/public RPC endpoints that use Biscuit bearer auth
# FIBER_NODE_RPC_AUTH_TOKEN=your_biscuit_token
# Fiber invoice network currency: Fibt=testnet, Fibb=mainnet, Fibd=dev
# FIBER_NODE_CURRENCY=Fibt
# Optional basic auth fallback for private/local nodes
# FIBER_NODE_RPC_USER=ckb
# FIBER_NODE_RPC_PASSWORD=your_password

# CORS origin for the admin dashboard
# Set to your dashboard URL in production, or leave as * for development
# CORS_ORIGIN=https://your-dashboard.com

# SQLite database path (default: ./data/merchant.db)
# FIBER_MERCHANT_DB_PATH=./data/merchant.db

# Rate limiting (defaults: 100 requests per 60 seconds)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
# Set to 'true' to disable rate limiting
# DISABLE_RATE_LIMIT=false
