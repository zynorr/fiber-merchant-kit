# ── Fiber Merchant Kit — API Server Configuration ──────────────
# Copy this file to .env and fill in your values.

# Server port (default: 3001)
PORT=3001

# Fiber Network Node RPC URL
# Set to your FNN node URL for production, or leave blank for demo mode
# FIBER_NODE_RPC_URL=http://localhost:8227

# Fiber Node RPC authentication (if required)
# FIBER_NODE_RPC_USER=ckb
# FIBER_NODE_RPC_PASSWORD=your_password

# CORS origin (set to your dashboard URL in production)
# CORS_ORIGIN=https://your-dashboard.com

# SQLite database path (default: ./data/merchant.db)
# FIBER_MERCHANT_DB_PATH=./data/merchant.db
