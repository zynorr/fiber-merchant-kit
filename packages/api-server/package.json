{
  "name": "@fiber-merchant/server",
  "version": "1.0.0",
  "private": true,
  "description": "Fiber Merchant Kit — Backend API Server with webhook delivery system",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format cjs",
    "dev": "tsup src/index.ts --format cjs --watch --onSuccess \"node dist/index.js\"",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "sql.js": "^1.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
