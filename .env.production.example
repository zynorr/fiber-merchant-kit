# Fiber Merchant Kit production environment

NODE_ENV=production
PORT=3001
CORS_ORIGIN=https://dashboard.example.com,https://store.example.com

# Persistence
FIBER_DB_ENGINE=sqlite
FIBER_MERCHANT_DB_PATH=/data/merchant.db
DATABASE_URL=

# Fiber node RPC. Use FIBER_NODE_RPC_URLS for failover across private nodes.
FIBER_NODE_RPC_URL=http://fiber-node-1:8227
FIBER_NODE_RPC_URLS=http://fiber-node-1:8227,http://fiber-node-2:8227
FIBER_NODE_CURRENCY=Fibt
FIBER_NODE_RPC_AUTH_TOKEN=
FIBER_NODE_RPC_USER=
FIBER_NODE_RPC_PASSWORD=

# Background workers
FIBER_SETTLEMENT_WORKER=true
FIBER_SETTLEMENT_WORKER_INTERVAL_MS=30000
FIBER_SETTLEMENT_WORKER_BATCH_SIZE=25
WEBHOOK_DELIVERY_WORKER=true
WEBHOOK_DELIVERY_WORKER_INTERVAL_MS=5000
WEBHOOK_DELIVERY_WORKER_BATCH_SIZE=25

# Rate limiting
DISABLE_RATE_LIMIT=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
