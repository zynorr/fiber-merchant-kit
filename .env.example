# Fiber Merchant Kit environment reference
#
# Package-specific examples live in:
# - packages/api-server/.env.example
# - packages/admin-dashboard/.env.example
# - packages/demo-store/.env.example
#
# The one-command start scripts copy those package examples to .env files.
# API server variables must be exported in the shell/deployment environment,
# or loaded by start.sh/start.ps1 from packages/api-server/.env.

# API server
NODE_ENV=development
PORT=3001
CORS_ORIGIN=*
FIBER_MERCHANT_DB_PATH=data/merchant.db

# Demo mode: leave unset or set to demo.
FIBER_NODE_RPC_URL=demo
FIBER_NODE_CURRENCY=Fibt
FIBER_NODE_RPC_AUTH_TOKEN=
FIBER_NODE_RPC_USER=
FIBER_NODE_RPC_PASSWORD=

# Background settlement worker. Leave FIBER_SETTLEMENT_WORKER unset to use
# the default behavior: disabled in demo mode, enabled in live mode.
FIBER_SETTLEMENT_WORKER_INTERVAL_MS=30000
FIBER_SETTLEMENT_WORKER_BATCH_SIZE=25

# Rate limiting
DISABLE_RATE_LIMIT=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Optional real testnet smoke knobs
FIBER_TESTNET_CREATE_INVOICE=false
FIBER_TESTNET_AMOUNT=1000
FIBER_TESTNET_EXPIRY=3600

# Frontend
VITE_MERCHANT_API_URL=
VITE_MERCHANT_API_KEY=
