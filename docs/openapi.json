    "/api/v1/fiber/settlement/run": {
      "post": {
        "tags": ["Fiber"],
        "summary": "Run settlement sweep",
        "operationId": "runSettlementSweep",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Settlement sweep completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SettlementRun"
                }
              }
            }
          },
          "202": {
            "description": "Settlement sweep skipped because another run is active",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SettlementRun"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "fm_sk"
      }
    },
    "parameters": {
      "Id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "DeliveryId": {
        "name": "deliveryId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 50
        }
      },
      "Cursor": {
        "name": "cursor",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Opaque pagination cursor returned by the previous page."
      },
      "IdempotencyKey": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": false,
        "schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "description": "Optional key for safely retrying create-invoice requests without creating duplicate invoices."
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid API key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "ValidationError": {
        "description": "Validation failed",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ValidationError"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Request conflicts with an existing idempotency record or resource state",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "ServerError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "Discovery": {
        "type": "object",
        "required": ["name", "version", "mode", "services", "publicEndpoints", "authenticatedResources", "reviewDocs"],
        "properties": {
          "name": {
            "type": "string",
            "example": "Fiber Merchant Kit"
          },
          "version": {
            "type": "string",
            "example": "1.0.0"
          },
          "mode": {
            "type": "string",
            "enum": ["demo", "live"]
          },
          "description": {
            "type": "string"
          },
          "services": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "publicEndpoints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "authenticatedResources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reviewDocs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Health": {
        "type": "object",
        "required": ["status", "version", "fiberNode"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["ok", "degraded"]
          },
          "version": {
            "type": "string"
          },
          "fiberNode": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/FiberNodeInfo"
              },
              {
                "type": "string",
                "enum": ["unreachable"]
              }
            ]
          }
        }
      },
      "FiberNodeInfo": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "node_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "peers": {
            "type": "integer"
          },
          "channels": {
            "type": "integer"
          }
        }
      },
      "CreateInvoiceRequest": {
        "type": "object",
        "required": ["amount"],
        "properties": {
          "amount": {
            "oneOf": [
              {
                "type": "string",
                "example": "5000"
              },
              {
                "type": "number",
                "example": 5000
              }
            ]
          },
          "currency": {
            "$ref": "#/components/schemas/Currency"
          },
          "description": {
            "type": "string",
            "maxLength": 500
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "expiry": {
            "type": "integer",
            "minimum": 1,
            "maximum": 86400,
            "default": 3600
          },
          "webhookUrl": {
            "type": "string",
            "format": "uri"
          },
          "allowMpp": {
            "type": "boolean"
          },
          "udtTypeScript": {
            "$ref": "#/components/schemas/UdtTypeScript"
          }
        }
      },
      "RefundInvoiceRequest": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "maxLength": 500
          }
        }
      },
      "Invoice": {
        "type": "object",
        "required": ["id", "paymentHash", "invoiceAddress", "amount", "currency", "status", "expiresAt", "createdAt", "updatedAt"],
        "properties": {
          "id": {
            "type": "string"
          },
          "paymentHash": {
            "type": "string"
          },
          "preimage": {
            "type": "string",
            "nullable": true
          },
          "invoiceAddress": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          },
          "currency": {
            "$ref": "#/components/schemas/Currency"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "metadata": {
            "type": "object",
            "nullable": true,
            "additionalProperties": {
              "type": "string"
            }
          },
          "status": {
            "$ref": "#/components/schemas/InvoiceStatus"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "paidAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time"
          },
          "refundedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time"
          },
          "webhookUrl": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "InvoiceList": {
        "type": "object",
        "required": ["items", "total"],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Invoice"
            }
          },
          "total": {
            "type": "integer"
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "InvoiceQr": {
        "type": "object",
        "required": ["invoiceAddress", "qrData"],
        "properties": {
          "invoiceAddress": {
            "type": "string"
          },
          "qrData": {
            "type": "string"
          }
        }
      },
      "CreateWebhookRequest": {
        "type": "object",
        "required": ["url", "events"],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "events": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/WebhookEvent"
            }
          },
          "description": {
            "type": "string",
            "maxLength": 200
          }
        }
      },
      "UpdateWebhookRequest": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "events": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/WebhookEvent"
            }
          },
          "description": {
            "type": "string",
            "maxLength": 200
          },
          "active": {
            "type": "boolean"
          }
        }
      },
      "Webhook": {
        "type": "object",
        "required": ["id", "url", "events", "secret", "active", "createdAt"],
        "properties": {
          "id": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WebhookEvent"
            }
          },
          "secret": {
            "type": "string",
            "description": "Returned when the webhook is created. Save it to verify HMAC signatures."
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "active": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "WebhookDelivery": {
        "type": "object",
        "required": ["id", "webhookId", "event", "url", "status", "success", "attempts", "deliveredAt"],
        "properties": {
          "id": {
            "type": "string"
          },
          "webhookId": {
            "type": "string"
          },
          "event": {
            "$ref": "#/components/schemas/WebhookEvent"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code, or 0 for network errors or queued delivery."
          },
          "success": {
            "type": "boolean"
          },
          "attempts": {
            "type": "integer"
          },
          "payload": {
            "type": "object",
            "additionalProperties": true
          },
          "error": {
            "type": "string",
            "nullable": true
          },
          "nextAttemptAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "When the durable webhook queue will retry this delivery, or null when no retry is scheduled."
          },
          "deliveredAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "WebhookRetryResponse": {
        "type": "object",
        "required": ["message", "delivery"],
        "properties": {
          "message": {
            "type": "string"
          },
          "delivery": {
            "$ref": "#/components/schemas/WebhookDelivery"
          }
        }
      },
      "WebhookTestResponse": {
        "type": "object",
        "required": ["message", "webhookId"],
        "properties": {
          "message": {
            "type": "string"
          },
          "webhookId": {
            "type": "string"
          }
        }
      },
      "Transaction": {
        "type": "object",
        "required": ["id", "paymentHash", "direction", "amount", "currency", "status", "createdAt"],
        "properties": {
          "id": {
            "type": "string"
          },
          "paymentHash": {
            "type": "string"
          },
          "invoiceId": {
            "type": "string",
            "nullable": true
          },
          "direction": {
            "type": "string",
            "enum": ["incoming", "outgoing"]
          },
          "amount": {
            "type": "string"
          },
          "currency": {
            "$ref": "#/components/schemas/Currency"
          },
          "fee": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "$ref": "#/components/schemas/TransactionStatus"
          },
          "counterparty": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "metadata": {
            "type": "object",
            "nullable": true,
            "additionalProperties": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TransactionList": {
        "type": "object",
        "required": ["items", "total"],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transaction"
            }
          },
          "total": {
            "type": "integer"
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "ChannelBalance": {
        "type": "object",
        "required": ["localBalance", "remoteBalance", "capacity", "asset"],
        "properties": {
          "localBalance": {
            "type": "string"
          },
          "remoteBalance": {
            "type": "string"
          },
          "capacity": {
            "type": "string"
          },
          "asset": {
            "type": "string"
          },
          "channelId": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "peerPubkey": {
            "type": "string"
          }
        }
      },
      "TotalBalance": {
        "type": "object",
        "required": ["local", "remote", "total"],
        "properties": {
          "local": {
            "type": "string"
          },
          "remote": {
            "type": "string"
          },
          "total": {
            "type": "string"
          }
        }
      },
      "Stats": {
        "type": "object",
        "required": ["totalInvoices", "paidInvoices", "totalVolume", "successRate", "activeChannels", "channelBalances"],
        "properties": {
          "totalInvoices": {
            "type": "integer"
          },
          "paidInvoices": {
            "type": "integer"
          },
          "totalVolume": {
            "type": "string"
          },
          "successRate": {
            "type": "integer"
          },
          "activeChannels": {
            "type": "integer"
          },
          "channelBalances": {
            "type": "object",
            "required": ["local", "remote"],
            "properties": {
              "local": {
                "type": "string"
              },
              "remote": {
                "type": "string"
              }
            }
          }
        }
      },
      "RevenueRow": {
        "type": "object",
        "required": ["date", "volume", "count"],
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "volume": {
            "type": "number"
          },
          "count": {
            "type": "integer"
          }
        }
      },
      "FiberStatus": {
        "type": "object",
        "required": ["mode", "reachable", "node", "channels", "worker"],
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["demo", "live"]
          },
          "reachable": {
            "type": "boolean"
          },
          "node": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/FiberNodeStatus"
              }
            ]
          },
          "channels": {
            "$ref": "#/components/schemas/FiberChannelStatus"
          },
          "worker": {
            "$ref": "#/components/schemas/SettlementWorkerStatus"
          },
          "config": {
            "type": "object",
            "additionalProperties": true
          },
          "error": {
            "type": "string"
          }
        }
      },
      "FiberNodeStatus": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "nodeId": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "peersCount": {
            "type": "integer"
          },
          "channelsCount": {
            "type": "integer"
          },
          "pendingChannelsCount": {
            "type": "integer"
          }
        }
      },
      "FiberChannelStatus": {
        "type": "object",
        "required": ["total", "ready", "pending", "localBalance", "remoteBalance", "capacity"],
        "properties": {
          "total": {
            "type": "integer"
          },
          "ready": {
            "type": "integer"
          },
          "pending": {
            "type": "integer"
          },
          "localBalance": {
            "type": "string"
          },
          "remoteBalance": {
            "type": "string"
          },
          "capacity": {
            "type": "string"
          },
          "assets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "SettlementWorkerStatus": {
        "type": "object",
        "required": ["enabled", "active", "running", "mode", "intervalMs", "batchSize"],
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "active": {
            "type": "boolean"
          },
          "running": {
            "type": "boolean"
          },
          "mode": {
            "type": "string",
            "enum": ["demo", "live"]
          },
          "intervalMs": {
            "type": "integer"
          },
          "batchSize": {
            "type": "integer"
          },
          "lastRunAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastSuccessAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastError": {
            "type": "string"
          },
          "lastSummary": {
            "$ref": "#/components/schemas/SettlementSummary"
          }
        }
      },
      "SettlementRun": {
        "type": "object",
        "required": ["trigger", "running", "skipped", "startedAt"],
        "properties": {
          "trigger": {
            "type": "string",
            "enum": ["timer", "manual"]
          },
          "running": {
            "type": "boolean"
          },
          "skipped": {
            "type": "boolean"
          },
          "startedAt": {
            "type": "string",
            "format": "date-time"
          },
          "finishedAt": {
            "type": "string",
            "format": "date-time"
          },
          "summary": {
            "$ref": "#/components/schemas/SettlementSummary"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "SettlementSummary": {
        "type": "object",
        "required": ["checked", "paid", "received", "expired", "unchanged", "errors"],
        "properties": {
          "checked": {
            "type": "integer"
          },
          "paid": {
            "type": "integer"
          },
          "received": {
            "type": "integer"
          },
          "expired": {
            "type": "integer"
          },
          "unchanged": {
            "type": "integer"
          },
          "errors": {
            "type": "integer"
          }
        }
      },
      "Currency": {
        "type": "string",
        "enum": ["CKB", "RUSD"],
        "default": "CKB"
      },
      "InvoiceStatus": {
        "type": "string",
        "enum": ["pending", "received", "paid", "expired", "cancelled", "refunded"]
      },
      "TransactionStatus": {
        "type": "string",
        "enum": ["Pending", "Succeeded", "Failed", "Timeout", "Abandoned"]
      },
      "WebhookEvent": {
        "type": "string",
        "enum": [
          "invoice.created",
          "invoice.received",
          "invoice.paid",
          "invoice.expired",
          "invoice.cancelled",
          "invoice.refunded",
          "payment.failed",
          "channel.updated"
        ]
      },
      "UdtTypeScript": {
        "type": "object",
        "required": ["codeHash", "hashType", "args"],
        "properties": {
          "codeHash": {
            "type": "string"
          },
          "hashType": {
            "type": "string"
          },
          "args": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "required": ["error", "details"],
        "properties": {
          "error": {
            "type": "string",
            "example": "Validation failed"
          },
          "details": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    }
  }
}
