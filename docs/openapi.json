    },
    "/api/v1/balance/total": {
      "get": {
        "tags": ["Balances"],
        "summary": "Get total Fiber channel balance",
        "operationId": "getTotalBalance",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Total balance",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TotalBalance"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/v1/stats": {
      "get": {
        "tags": ["Stats"],
        "summary": "Get dashboard stats",
        "operationId": "getStats",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Dashboard stats",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Stats"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/v1/stats/revenue": {
      "get": {
        "tags": ["Stats"],
        "summary": "Get revenue history",
        "operationId": "getRevenueHistory",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "days",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "default": 30
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Revenue history rows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RevenueRow"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/v1/fiber/status": {
      "get": {
        "tags": ["Fiber"],
        "summary": "Get Fiber node and worker status",
        "operationId": "getFiberStatus",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Fiber node, channel, and settlement worker status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FiberStatus"
                }
